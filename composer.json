{
    "name": "aureuserp/advance-table-repeater",
    "description": "Advanced Filament v5 Repeater + RepeatableEntry with table view, column manager, drag-drop, resizable columns, and summarizers (sum/count/avg/range).",
    "keywords": ["webkul", "laravel", "filamentphp", "filament", "filament-plugin", "repeater", "advance-table-repeater"],
    "homepage": "https://github.com/aureuserp/advance-table-repeater",
    "license": "MIT",
    "authors": [
        {"name": "Webkul", "email": "support@webkul.com", "role": "Developer"}
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/infolists": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\AdvanceTableRepeater\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\AdvanceTableRepeater\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\AdvanceTableRepeater\\AdvanceTableRepeaterServiceProvider"
            ]
        }
    },
    "config": {"sort-packages": true},
    "minimum-stability": "stable",
    "prefer-stable": true
}
